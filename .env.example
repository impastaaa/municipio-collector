# PostgreSQL connection string (Supabase or self-hosted)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/municipio_collector

# Public app URL (used for OG tags)
NEXT_PUBLIC_APP_URL=https://municipiocollector.es

# Cloudflare R2
# Public CDN URL for bucket (set up a custom domain in R2 settings)
R2_PUBLIC_URL=https://images.municipiocollector.es
# Also add this as an env var for next.config.ts hostname matching
R2_PUBLIC_HOSTNAME=images.municipiocollector.es

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=municipios

# Google AdSense rewarded ad client (skip in development)
ADSENSE_AD_CLIENT=ca-pub-xxxxx
